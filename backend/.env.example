# Backend environment variables
# Copy this file to .env and fill your values

# Server
PORT=3000

# Groq (used by /api/ai-report-summary and /api/ai-chat)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OCR + fix suggestion routes
OCR_SPACE_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
