# Backend environment variables
# Copy this file to .env and fill your values

# Server
PORT=3000

# Chatbot / AI (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OCR (Roboflow)
# Set your Roboflow API key and model coordinates.
# Keys can also be provided per-request via headers from frontend runtime settings.
ROBOFLOW_API_KEY=
ROBOFLOW_PROJECT_NAME=your-project-name
ROBOFLOW_PROJECT_VERSION=1
ROBOFLOW_WORKSPACE=
