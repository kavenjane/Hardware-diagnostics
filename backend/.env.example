# Backend environment variables
# Copy this file to .env and fill your values

# Server
PORT=3000

# Chatbot / AI (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OCR (Google Vision - primary)
# Used by /api/ocr in auto mode when present.
GOOGLE_VISION_API_KEY=

# OCR (Roboflow - optional fallback)
# Set your Roboflow API key and model coordinates if you want fallback support.
# Keys can also be provided per-request via headers from frontend runtime settings.
ROBOFLOW_API_KEY=
ROBOFLOW_PROJECT_NAME=your-project-name
ROBOFLOW_PROJECT_VERSION=1
ROBOFLOW_WORKSPACE=
